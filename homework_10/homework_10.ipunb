      "source": [
        "# Корреляция"
      ],
      "metadata": {
        "id": "qxiCYIRlxaNS"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# корреляция\n",
        "corr_col = ['price', 'latitude', 'longitude', 'minimum_nights',\n",
        "           'number_of_reviews', 'reviews_per_month', 'calculated_host_listings_count', 'availability_365']\n",
        "corr = data[corr_col].corr()\n",
        "plt.title(\"Корреляционная матрица\")\n",
        "sns.heatmap(corr, annot=True, fmt='.2f', square=True, cmap=\"coolwarm\");"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 649
        },
        "id": "qKhMlSAzyx3U",
        "outputId": "adce8b3d-b7ad-4bee-fa9d-4e5aaf42c074"
