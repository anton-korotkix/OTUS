    {
      "cell_type": "markdown",
      "source": [
        "# Preprocessing"
      ],
      "metadata": {
        "id": "4GFWBUwqx8LB"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# препроцессинг (х - все колонки, но без цены; у - только целевая колонка цена)\n",
        "data.drop(columns=['neighbourhood','room_type','neighbourhood_group'], axis=1, inplace=True)\n",
        "\n",
        "X = data.drop('price', axis=1)\n",
        "y = data['price']\n",
        "\n",
        "X.shape, y.shape"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "J8-l85CR9kDv",
        "outputId": "3a8f08dc-30cc-49bb-e1e2-864c7a082302"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": [
              "((48895, 16), (48895,))"
            ]
          },
          "metadata": {},
          "execution_count": 96
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Разбивка данных (30% тестовый набор)\n",
        "X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)\n",
        "X_train.shape, X_test.shape, y_train.shape, y_test.shape"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "wdzFxvGi-_dd",
        "outputId": "1d7dd012-c79b-4f59-bc76-d8d12711fcee"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "execute_result",
          "data": {
            "text/plain": [
              "((34226, 16), (14669, 16), (34226,), (14669,))"
            ]
          },
          "metadata": {},
          "execution_count": 97
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "# Моделирование"
      ],
      "metadata": {
        "id": "mf9M_3eJxyaF"
