    {
      "cell_type": "code",
      "source": [
        "# пересчет всех регрессий\n",
        "def all_regressions(X_train, X_test, y_train, y_test):\n",
        "    metrics_table = init_metrics_table()\n",
        "\n",
        "    regression(X_train, X_test, y_train, y_test, LinearRegression(), 'LinearRegression', metrics_table, False)\n",
        "    regression(X_train, X_test, y_train, y_test, RidgeCV(), 'RidgeCV', metrics_table, False)\n",
        "    regression(X_train, X_test, y_train, y_test, LassoCV(), 'LassoCV', metrics_table, False)\n",
        "    regression(X_train, X_test, y_train, y_test, ElasticNetCV(), 'ElasticNetCV', metrics_table, False)\n",
        "\n",
        "    return metrics_table\n",
        "\n",
        "metrics_table = all_regressions(X_train, X_test, y_train, y_test)\n",
        "metrics_table"
      ],
