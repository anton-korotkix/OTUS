    {
      "cell_type": "code",
      "source": [
        "# обработка категориальных переменных neighbourhood_group\n",
        "data['neighbourhood_group'].hist()\n",
        "plt.show()\n",
        "data['neighbourhood_group'].value_counts()\n",
        "neighbourhood_group_encoded = pd.get_dummies(data['neighbourhood_group'], prefix='neighbourhood_group')\n",
        "data = pd.concat([data, neighbourhood_group_encoded], axis=1)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
